[gd_scene format=3 uid="uid://68k2ekg5xpq6"]

[ext_resource type="Script" uid="uid://bep86e2hgd83r" path="res://example/Interactive.gd" id="1"]

[sub_resource type="NkidoAudioStream" id="NkidoAudioStream_1"]
source = "cutoff= param(\"cutoff\", 2000, 10, 8000)
resonance= param(\"resonance\", 0.3, 0, 10)
__reverb= param(\"reverb\", 0.3, 0, 1)
volume= param(\"volume\", 0.5, 0, 1)
chorus_on= toggle(\"chorus_on\")
hit = button(\"hit\")

sine(220) as s
saw(220) as w
sqr(220) as q
osc(\"saw\", 220) as voice1
sqr(110) as voice2

adsr(hit, 0.01, 0.2, 0.4, 0.5) as env1
ar(trigger(1), 0.0, 0.1) as env2
voice1 * env1  +  voice2 * env2 |> lp(%, cutoff, resonance) as filtered

chorus(filtered, 0.3, 0.05) as wet_chorus
select(chorus_on, filtered, wet_chorus) as post_fx

freeverb(post_fx, 0.85, 0.3) as verb
post_fx * (1.0 - __reverb) + verb * __reverb as mixed

mixed * volume |> out(%, %)"

